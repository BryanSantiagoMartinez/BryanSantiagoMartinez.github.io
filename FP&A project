<style>
* { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior:smooth; }
:root {
  --bg:      #f7f7f6;
  --surface: #ffffff;
  --border:  #e5e5e3;
  --border2: #d4d4d1;
  --ink:     #1a1a18;
  --ink2:    #3d3d3a;
  --muted:   #8c8c88;
  --muted2:  #b0b0ac;
  --green:   #16a34a;
  --red:     #dc2626;
}
body { background:var(--bg); color:var(--ink); font-family:'Geist',sans-serif; font-size:15px; line-height:1.6; -webkit-font-smoothing:antialiased; }
nav { position:fixed; top:0; width:100%; z-index:100; background:rgba(247,247,246,0.92); backdrop-filter:blur(10px); border-bottom:1px solid var(--border); padding:0 2.5rem; height:52px; display:flex; align-items:center; justify-content:space-between; }
.nav-logo { font-family:'Geist Mono',monospace; font-size:0.72rem; letter-spacing:0.08em; color:var(--muted); text-decoration:none; transition:color 0.15s; }
.nav-logo:hover { color:var(--ink); }
.nav-back { font-family:'Geist Mono',monospace; font-size:0.72rem; letter-spacing:0.06em; color:var(--muted); text-decoration:none; transition:color 0.15s; }
.nav-back:hover { color:var(--ink); }

.hero { padding:7rem 2.5rem 4rem; max-width:800px; margin:0 auto; border-bottom:1px solid var(--border); }
.hero-meta-top { display:flex; align-items:center; gap:1.5rem; margin-bottom:2rem; flex-wrap:wrap; }
.hero-tag { font-family:'Geist Mono',monospace; font-size:0.68rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--muted); }
.hero-dot { width:3px; height:3px; border-radius:50%; background:var(--border2); }
.hero h1 { font-family:'Instrument Serif',serif; font-size:clamp(2.4rem,5vw,3.6rem); font-weight:400; line-height:1.1; letter-spacing:-0.02em; color:var(--ink); margin-bottom:1.4rem; }
.hero h1 em { font-style:italic; color:var(--muted); }
.hero-lead { font-size:1.05rem; color:var(--ink2); line-height:1.75; max-width:620px; margin-bottom:2.5rem; }
.hero-attrs { display:flex; gap:2.5rem; flex-wrap:wrap; }
.attr { display:flex; flex-direction:column; gap:0.15rem; }
.attr-label { font-family:'Geist Mono',monospace; font-size:0.62rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--muted2); }
.attr-value { font-size:0.88rem; color:var(--ink2); font-family:'Geist Mono',monospace; }

.metrics-strip { border-bottom:1px solid var(--border); background:var(--surface); }
.metrics-inner { max-width:800px; margin:0 auto; padding:0 2.5rem; display:grid; grid-template-columns:repeat(4,1fr); }
.metric { padding:1.6rem 0 1.6rem 1.5rem; border-right:1px solid var(--border); }
.metric:first-child { padding-left:0; }
.metric:last-child { border-right:none; }
.metric-num { font-family:'Instrument Serif',serif; font-size:2rem; font-weight:400; color:var(--ink); line-height:1; margin-bottom:0.3rem; }
.metric-label { font-family:'Geist Mono',monospace; font-size:0.62rem; letter-spacing:0.08em; text-transform:uppercase; color:var(--muted); }

.page-layout { max-width:800px; margin:0 auto; padding:0 2.5rem; }

.section { padding:4rem 0; border-bottom:1px solid var(--border); }
.section:last-child { border-bottom:none; }
.section-num { font-family:'Geist Mono',monospace; font-size:0.62rem; letter-spacing:0.12em; text-transform:uppercase; color:var(--muted2); margin-bottom:0.6rem; }
.section h2 { font-family:'Instrument Serif',serif; font-size:1.7rem; font-weight:400; letter-spacing:-0.01em; color:var(--ink); margin-bottom:1.4rem; line-height:1.2; }
.prose { color:var(--ink2); font-size:0.97rem; line-height:1.8; margin-bottom:1.2rem; }
.prose strong { color:var(--ink); font-weight:500; }
.prose em { font-style:italic; color:var(--muted); }

.pull-quote { margin:2rem 0; padding:1.4rem 0 1.4rem 1.6rem; border-left:2px solid var(--ink); }
.pull-quote p { font-family:'Instrument Serif',serif; font-size:1.2rem; font-style:italic; color:var(--ink2); line-height:1.6; }
.pull-quote p strong { font-style:normal; color:var(--ink); }

.data-table { width:100%; border-collapse:collapse; margin:1.8rem 0; font-family:'Geist Mono',monospace; font-size:0.8rem; }
.data-table thead tr { border-bottom:1px solid var(--ink); }
.data-table th { padding:0.6rem 0.8rem 0.6rem 0; text-align:left; font-weight:500; color:var(--ink); letter-spacing:0.04em; font-size:0.72rem; text-transform:uppercase; }
.data-table td { padding:0.6rem 0.8rem 0.6rem 0; color:var(--ink2); border-bottom:1px solid var(--border); }
.data-table tbody tr:last-child td { border-bottom:none; }
.val-pos { color:var(--green); }
.val-neg { color:var(--red); }
.val-hi  { color:var(--ink); font-weight:500; }
.val-dim { color:var(--muted2); }

.findings { display:grid; grid-template-columns:1fr 1fr; gap:1px; background:var(--border); border:1px solid var(--border); margin:2rem 0; }
.finding { background:var(--surface); padding:1.6rem; }
.finding-stat { font-family:'Instrument Serif',serif; font-size:2.2rem; color:var(--ink); line-height:1; margin-bottom:0.5rem; }
.finding-title { font-family:'Geist Mono',monospace; font-size:0.68rem; letter-spacing:0.08em; text-transform:uppercase; color:var(--muted); margin-bottom:0.5rem; }
.finding-body { font-size:0.88rem; color:var(--ink2); line-height:1.6; }

.insight { background:var(--surface); border:1px solid var(--border); padding:1.4rem 1.6rem; margin:1.8rem 0; display:flex; gap:1rem; align-items:flex-start; }
.insight-icon { font-family:'Geist Mono',monospace; font-size:0.65rem; color:var(--muted2); letter-spacing:0.08em; text-transform:uppercase; padding-top:0.1rem; flex-shrink:0; min-width:2.5rem; }
.insight-text { font-size:0.93rem; color:var(--ink2); line-height:1.7; }
.insight-text strong { color:var(--ink); font-weight:500; }

/* Architecture diagram */
.arch { display:grid; grid-template-columns:1fr auto 1fr auto 1fr; gap:0; align-items:center; margin:2rem 0; background:var(--surface); border:1px solid var(--border); padding:1.8rem; }
.arch-box { text-align:center; }
.arch-box-title { font-family:'Geist Mono',monospace; font-size:0.72rem; font-weight:500; color:var(--ink); letter-spacing:0.06em; text-transform:uppercase; margin-bottom:0.4rem; }
.arch-box-sub { font-family:'Geist Mono',monospace; font-size:0.62rem; color:var(--muted); line-height:1.6; }
.arch-arrow { font-family:'Geist Mono',monospace; font-size:0.9rem; color:var(--muted2); text-align:center; padding:0 1rem; }

/* Pipeline steps */
.pipeline { display:flex; flex-direction:column; gap:1px; background:var(--border); border:1px solid var(--border); margin:1.8rem 0; }
.pipeline-step { background:var(--surface); padding:1.2rem 1.6rem; display:grid; grid-template-columns:2rem 1fr; gap:1.2rem; align-items:baseline; }
.pipeline-num { font-family:'Geist Mono',monospace; font-size:0.68rem; color:var(--muted2); }
.pipeline-content { }
.pipeline-title { font-size:0.93rem; font-weight:500; color:var(--ink); margin-bottom:0.2rem; }
.pipeline-desc { font-size:0.88rem; color:var(--ink2); line-height:1.6; }

/* Dashboard preview placeholder */
.dashboard-preview { background:var(--surface); border:1px solid var(--border); padding:1.5rem; margin:1.8rem 0; }
.dashboard-label { font-family:'Geist Mono',monospace; font-size:0.62rem; color:var(--muted2); letter-spacing:0.08em; text-transform:uppercase; text-align:center; margin-top:1rem; }

/* KPI row */
.kpi-row { display:grid; grid-template-columns:repeat(5,1fr); gap:1px; background:var(--border); border:1px solid var(--border); margin-bottom:1px; }
.kpi-box { background:var(--surface); padding:0.9rem 1rem; text-align:center; }
.kpi-num { font-family:'Instrument Serif',serif; font-size:1.1rem; color:var(--ink); }
.kpi-lbl { font-family:'Geist Mono',monospace; font-size:0.58rem; color:var(--muted2); letter-spacing:0.06em; text-transform:uppercase; margin-top:0.2rem; }

/* Chart grid */
.chart-grid { display:grid; grid-template-columns:1fr 1fr; gap:1px; background:var(--border); border:1px solid var(--border); }
.chart-box { background:var(--surface); padding:1.2rem; }
.chart-title { font-family:'Geist Mono',monospace; font-size:0.65rem; color:var(--muted); letter-spacing:0.06em; text-transform:uppercase; margin-bottom:0.8rem; }

/* Limit list */
.limit-list { list-style:none; margin:1rem 0; }
.limit-list li { padding:0.9rem 0; border-bottom:1px solid var(--border); display:grid; grid-template-columns:8rem 1fr; gap:1rem; align-items:baseline; }
.limit-list li:last-child { border-bottom:none; }
.limit-tag { font-family:'Geist Mono',monospace; font-size:0.68rem; letter-spacing:0.06em; text-transform:uppercase; color:var(--muted); }
.limit-text { font-size:0.92rem; color:var(--ink2); line-height:1.6; }
.limit-text strong { color:var(--ink); font-weight:500; }

/* Bottom */
.page-bottom { max-width:800px; margin:0 auto; padding:2rem 2.5rem; display:flex; justify-content:space-between; align-items:center; border-top:1px solid var(--border); }
.btn { font-family:'Geist Mono',monospace; font-size:0.72rem; letter-spacing:0.06em; padding:0.55rem 1.1rem; border-radius:3px; text-decoration:none; transition:all 0.15s; }
.btn-ghost { border:1px solid var(--border); color:var(--muted); }
.btn-ghost:hover { border-color:var(--ink); color:var(--ink); }
.btn-solid { background:var(--ink); color:#f7f7f6; border:1px solid var(--ink); }
.btn-solid:hover { background:var(--ink2); }

/* TOC */
@media (min-width:1200px) {
  .page-layout { max-width:1050px; display:grid; grid-template-columns:1fr 180px; gap:4rem; align-items:start; }
  .toc-sidebar { position:sticky; top:70px; padding-top:4rem; }
  .toc-label { font-family:'Geist Mono',monospace; font-size:0.62rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--muted2); margin-bottom:0.8rem; }
  .toc-link { display:block; font-family:'Geist Mono',monospace; font-size:0.7rem; color:var(--muted2); text-decoration:none; padding:0.3rem 0 0.3rem 0.7rem; margin-left:-0.7rem; border-left:1px solid transparent; transition:all 0.15s; }
  .toc-link:hover, .toc-link.active { color:var(--ink); border-left-color:var(--ink); }
}
@media (max-width:1199px) { .toc-sidebar { display:none; } }
@media (max-width:700px) {
  .hero, .page-layout { padding-left:1.5rem; padding-right:1.5rem; }
  .metrics-inner { grid-template-columns:1fr 1fr; padding:0 1.5rem; }
  .findings, .kpi-row, .chart-grid { grid-template-columns:1fr; }
  .arch { grid-template-columns:1fr; gap:0.5rem; }
  .arch-arrow { transform:rotate(90deg); }
  .limit-list li { grid-template-columns:1fr; gap:0.2rem; }
  .page-bottom { flex-direction:column; gap:1rem; }
}
</style>
